# Environment Variables for MindMesh
#
# Copy this file to .env and fill in your actual values.
# Never commit the .env file to version control.

# Database Configuration
# PostgreSQL database settings
POSTGRES_DB=mindmesh
POSTGRES_USER=mindmesh_user
POSTGRES_PASSWORD=mindmesh_password
POSTGRES_PORT=5433

# Full database connection URL (constructed from above or provided directly)
DATABASE_URL=postgresql://mindmesh_user:mindmesh_password@postgres:5432/mindmesh

# Vector Database Configuration
# Qdrant vector database URL
QDRANT_URL=http://localhost:6335
QDRANT_COLLECTION=mindmesh_memories
QDRANT_NOTES_COLLECTION=notes
QDRANT_DOCUMENTS_COLLECTION=documents
QDRANT_HTTP_PORT=6335
QDRANT_GRPC_PORT=6336
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# AI Provider Configuration
# Groq API key for AI-powered features
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=

# Application Configuration
# Backend service host and port
BACKEND_HOST=localhost
BACKEND_PORT=8000

# Frontend service port
FRONTEND_PORT=8501

# Development settings
APP_ENV=development
DEBUG=true

# Security
# Secret key for JWT tokens and other cryptographic operations
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:8501,http://frontend:8501,http://localhost:5173
LOG_LEVEL=INFO

# MinIO document storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=mindmesh
MINIO_SECRET_KEY=mindmesh-password
MINIO_BUCKET=mindmesh-documents
MINIO_SECURE=false
MINIO_DATA_PATH=/minio-data

# Single-user local frontend lockscreen
WORKSPACE_PIN=
SINGLE_USER_EMAIL=local@mindmesh.app
SINGLE_USER_PASSWORD=mindmesh-local-workspace-password

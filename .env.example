# MindMesh environment template
#
# Copy this file to .env for local Docker runs:
#   cp .env.example .env
#
# Do not commit .env. The values below are safe local defaults except where
# explicitly marked as secrets/placeholders.

# PostgreSQL
POSTGRES_DB=mindmesh
POSTGRES_USER=mindmesh_user
POSTGRES_PASSWORD=change-this-local-db-password
POSTGRES_PORT=5433
# Set DATABASE_URL when connecting to an already-running Postgres container.
# If omitted, scripts/start-local.ps1 builds one from the POSTGRES_* values.
# DATABASE_URL=postgresql://mindmesh_user:change-this-local-db-password@localhost:5432/mindmesh

# Backend security
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:8501,http://127.0.0.1:8501,http://frontend:8501

# AI and tools
# Optional at startup. Users can also add provider API keys from Settings > AI.
GROQ_API_KEY=
TAVILY_API_KEY=

# Qdrant
QDRANT_HTTP_PORT=6335
QDRANT_GRPC_PORT=6336
QDRANT_URL=http://localhost:6335
QDRANT_NOTES_COLLECTION=notes
QDRANT_DOCUMENTS_COLLECTION=documents
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# MinIO-compatible local document storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Existing local envs that use MINIO_USER/MINIO_PASSWORD are also supported.
MINIO_BUCKET=mindmesh-documents
MINIO_SECURE=false
MINIO_DATA_PATH=.mindmesh-data/minio

# Frontend local workspace lock and bootstrap user
WORKSPACE_PIN=
SINGLE_USER_EMAIL=local@mindmesh.app
SINGLE_USER_PASSWORD=change-this-local-workspace-password

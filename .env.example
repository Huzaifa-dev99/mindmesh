APP_HOST=127.0.0.1
APP_PORT=8000
STREAMLIT_HOST=127.0.0.1
STREAMLIT_PORT=8501
LOG_LEVEL=INFO
MM_POC_LOG_MAX_BYTES=10485760
MM_POC_LOG_BACKUP_COUNT=5
# Optional Fernet key for encrypting admin-stored provider API keys.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ADMIN_SECRET_KEY=

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=mm_poc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=disable
# Optional alternative to POSTGRES_* fields:
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/mm_poc

S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=mmpoc
S3_PREFIX=pdf/
S3_REGION_NAME=us-east-1
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_USE_SSL=false
S3_VERIFY_SSL=false

CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=4
RETRIEVER_SCORE_THRESHOLD=0.0

TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
TAVILY_INCLUDE_ANSWER=true
TAVILY_INCLUDE_RAW_CONTENT=false

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=documents
QDRANT_DISTANCE=COSINE
QDRANT_RECREATE_COLLECTION=false

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
CONTENT_PAYLOAD_KEY=page_content
METADATA_PAYLOAD_KEY=metadata

DOCUMENT_TAGS=
DOCUMENT_APPLICABLE_DATA=
DOCUMENT_VERSION=
DOCUMENT_REGISTRY_PATH=data/document_registry.json

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MAX_TOKENS=1024
GROQ_TEMPERATURE=0
